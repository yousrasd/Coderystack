---
import Base from "@/layouts/Base.astro";

export const prerender = true;

---

<Base>
	<section class="max-w-3xl mx-auto py-10 px-5 md:px-12">

		<h1 class="text-3xl md:text-4xl font-bold text-text-heading dark:text-text-heading-dark mb-6">Hi there 👋</h1>

		<p class="text-text-body dark:text-text-body-dark leading-relaxed mb-6">
			I'm a mobile developer with experience working across both backend and frontend projects.
			I enjoy learning new skills and building products that create a positive impact on our society. 🌱💡
		</p>

		<p class="text-text-body dark:text-text-body-dark leading-relaxed">
			Want to connect? Feel free to reach out on
			<a href="https://www.linkedin.com/in/yousra-saidani-836341165/" target="_blank" class="text-primary-color hover:underline">LinkedIn</a>!
		</p>

	</section>
</Base>
